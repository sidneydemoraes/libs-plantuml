' Configure layout
!global $FONT_COLOR?="#3b3b3b"
!global $FONT_SIZE_XS?=10
!global $FONT_SIZE_SM?=12
!global $FONT_SIZE_MD?=16
!global $FONT_SIZE_LG?=20


' Common Procedures
!procedure Title($title, $subtitle="", $version="", $date="")
  left header
  <color:$FONT_COLOR><size:$FONT_SIZE_LG>$title</size></color>
  !if ($subtitle)
    <color:$FONT_COLOR><size:$FONT_SIZE_MD>$subtitle</size></color>
  !endif
  !if ($version)
    <color:$FONT_COLOR><size:$FONT_SIZE_MD>"Version: " + $version</size></color>
  !endif
  !if ($date)
    <color:$FONT_COLOR><size:$FONT_SIZE_MD>"Last modified: " + $date</size></color>
  !endif
  end header
!endprocedure

!procedure SketchMode()
  !option handwritten true
!endprocedure

!unquoted procedure Card($id, $shape, $stereotype, $name="")
  !if ($name == "")
    $name = "$id"
  !endif
  $shape $id <<$stereotype>> as "$name"
!endprocedure
